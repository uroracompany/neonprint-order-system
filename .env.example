VITE_SUPABASE_URL="https://tu-proyecto.supabase.co"
VITE_SUPABASE_ANON_KEY="tu_anon_key"

# Solo para endpoints/server-side. Nunca usar con prefijo VITE_.
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu_service_role_key"
ORDER_PURGE_CRON_SECRET="un_token_largo_y_aleatorio"

# Storage hibrido. Mantener "supabase" hasta configurar R2.
STORAGE_PROVIDER="supabase"
R2_UPLOAD_THRESHOLD_MB="25"
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_DEV="neonprint-order-files-dev"
R2_BUCKET_PROD="neonprint-order-files-prod"

# ⚠️ NUNCA agregues SUPABASE_SERVICE_ROLE_KEY con prefijo VITE_.
# Vite expone en el bundle del cliente cualquier variable con prefijo VITE_.
